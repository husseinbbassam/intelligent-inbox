# Copy this file to .env and fill in the values before running the server.
# Never commit the real .env file to version control.

# PostgreSQL connection string
POSTGRES_DSN=postgres://inbox:inbox_secret@localhost:5432/intelligent_inbox?sslmode=disable

# Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

# HTTP server port (default: 8080)
PORT=8080
